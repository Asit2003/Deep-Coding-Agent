# Deep Coding Agent - sample environment configuration
# Copy this file to `.env` and fill in your real values.

# Model settings (OpenAI only)
AGENT_TEMPERATURE=0.1

# OpenAI settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Planning and execution limits
PLANNING_MAX_STEPS=8
MAX_TOOL_ROUNDS=10
MAX_GRAPH_ITERATIONS=2
MAX_PARALLEL_TASKS=3

# Project paths and commands
AGENT_PROJECTS_ROOT=project
AGENT_PLAN_FILE=agent_plan.md
AGENT_TEST_COMMAND=uv run pytest -q
